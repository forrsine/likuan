digraph NFA {
  rankdir=LR;
  graph [bgcolor="white", pad="0.2"];
  node [shape=circle, fontname="Consolas", fontsize=10];
  edge [fontname="Consolas", fontsize=9];
  start [shape=point, label=""];
  start -> q4;
  q0 [label="0"];
  q1 [label="1"];
  q2 [label="2"];
  q3 [label="3"];
  q4 [label="4"];
  q5 [label="5", shape=doublecircle];
  q0 -> q1 [label="[a]"];
  q1 -> q5 [label="eps"];
  q2 -> q3 [label="[b]"];
  q3 -> q5 [label="eps"];
  q4 -> q0 [label="eps"];
  q4 -> q2 [label="eps"];
}
